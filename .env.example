VITE_API_BASE_URL=https://skyops-api.uaeftt-ute.site/api

# Client ID (tipo "Web application") de Google Cloud Console > APIs & Services
# > Credentials. Es público (va en el HTML), no un secreto. El backend
# necesita el mismo valor en GOOGLE_OAUTH_CLIENT_ID para verificar el token.
VITE_GOOGLE_CLIENT_ID=
